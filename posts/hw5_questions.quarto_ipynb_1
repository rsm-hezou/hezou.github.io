   "source": [
    "#| label: helper-functions\n",
    "#| echo: true\n",
    "#| code-fold: false\n",
    "def standardize_vector(x):\n",
    "    x = np.asarray(x, dtype=float)\n",
    "    return (x - np.mean(x)) / np.std(x, ddof=1)\n",
    "\n",
    "\n",
    "def standardize_matrix(X):\n",
    "    X = np.asarray(X, dtype=float)\n",
    "    means = np.mean(X, axis=0)\n",
    "    sds = np.std(X, axis=0, ddof=1)\n",
    "    return (X - means) / sds\n",
    "\n",
    "\n",
    "def normalize_to_100(values, use_absolute=True):\n",
    "    values = np.asarray(values, dtype=float)\n",
    "\n",
    "    if use_absolute:\n",
    "        values = np.abs(values)\n",
    "    else:\n",
    "        values = np.where(values < 0, 0, values)\n",
    "\n",
    "    total = np.sum(values)\n",
    "\n",
    "    if total == 0:\n",
    "        return np.repeat(np.nan, len(values))\n",
    "\n",
    "    return 100 * values / total\n",
    "\n",
    "\n",
    "def r2_score_for_features(X, y, feature_indices):\n",
    "    feature_indices = list(feature_indices)\n",
    "\n",
    "    if len(feature_indices) == 0:\n",
    "        return 0.0\n",
    "\n",
    "    model = LinearRegression()\n",
    "    model.fit(X[:, feature_indices], y)\n",
    "\n",
    "    return model.score(X[:, feature_indices], y)\n",
    "\n",
    "\n",
    "def exact_shapley_r2_values(X, y):\n",
    "    \"\"\"\n",
    "    Exact LMG / Shapley values using linear regression R-squared\n",
    "    as the fit metric.\n",
    "    \"\"\"\n",
    "    p = X.shape[1]\n",
    "    p_factorial = math.factorial(p)\n",
    "\n",
    "    r2_cache = {}\n",
    "\n",
    "    def r2_for_mask(mask):\n",
    "        if mask not in r2_cache:\n",
    "            feature_indices = [\n",
    "                j for j in range(p)\n",
    "                if mask & (1 << j)\n",
    "            ]\n",
    "            r2_cache[mask] = r2_score_for_features(X, y, feature_indices)\n",
    "        return r2_cache[mask]\n",
    "\n",
    "    shapley_values = np.zeros(p)\n",
    "\n",
    "    for j in range(p):\n",
    "        for mask in range(1 << p):\n",
    "            if mask & (1 << j):\n",
    "                continue\n",
    "\n",
    "            subset_size = mask.bit_count()\n",
    "\n",
    "            weight = (\n",
    "                math.factorial(subset_size)\n",
    "                * math.factorial(p - subset_size - 1)\n",
    "                / p_factorial\n",
    "            )\n",
    "\n",
    "            r2_without_j = r2_for_mask(mask)\n",
    "            r2_with_j = r2_for_mask(mask | (1 << j))\n",
    "\n",
    "            shapley_values[j] += weight * (r2_with_j - r2_without_j)\n",
    "\n",
    "    return shapley_values\n",
    "\n",
    "\n",
    "def johnson_relative_weights(X_z, y_z):\n",
    "    \"\"\"\n",
    "    Johnson's relative weights.\n",
    "\n",
    "    This decomposes model R-squared into predictor-specific contributions\n",
    "    while accounting for correlation among predictors.\n",
    "    \"\"\"\n",
    "    p = X_z.shape[1]\n",
    "\n",
    "    Rxx = np.corrcoef(X_z, rowvar=False)\n",
    "\n",
    "    rxy = np.array([\n",
    "        np.corrcoef(X_z[:, j], y_z)[0, 1]\n",
    "        for j in range(p)\n",
    "    ])\n",
    "\n",
    "    eigenvalues, eigenvectors = np.linalg.eigh(Rxx)\n",
    "    eigenvalues = np.clip(eigenvalues, 0, None)\n",
    "\n",
    "    lambda_matrix = (\n",
    "        eigenvectors\n",
    "        @ np.diag(np.sqrt(eigenvalues))\n",
    "        @ eigenvectors.T\n",
    "    )\n",
    "\n",
    "    beta_star = np.linalg.pinv(lambda_matrix) @ rxy\n",
    "\n",
    "    raw_weights = (lambda_matrix ** 2) @ (beta_star ** 2)\n",
    "    raw_weights = np.clip(raw_weights, 0, None)\n",
    "\n",
    "    return raw_weights"
   ]
