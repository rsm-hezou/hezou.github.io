      "source": [
        "## MNL via Maximum Likelihood\n",
        "\n",
        "For one task, the log-likelihood contribution is the log probability of the observed best choice plus the log probability of the observed conditional worst choice. Summing over all tasks,\n",
        "\n",
        "$$\n",
        "\\ell(\\boldsymbol{\\beta}) =\n",
        "\\sum_{\\text{tasks}}\n",
        "\\left[\n",
        "\\beta_{j_b^*}\n",
        "- \\log\\sum_{j \\in \\text{shown}}\\exp(\\beta_j)\n",
        "- \\beta_{j_w^*}\n",
        "- \\log\\sum_{j \\in \\text{shown}\\setminus \\{j_b^*\\}}\\exp(-\\beta_j)\n",
        "\\right],\n",
        "$$\n",
        "\n",
        "where $j_b^*$ is the selected best item and $j_w^*$ is the selected worst item.\n",
        "\n",
        "The following code is the core MNL likelihood and optimizer code. It is shown because it is the main model-building part of the analysis. The first class is pinned to zero for identification, and the optimizer estimates the remaining nine coefficients."
      ],
      "id": "835d24f7"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: mle-core-code\n",
        "#| echo: true\n",
        "def full_beta(theta):\n",
        "    \"\"\"theta has length J-1. The first beta is pinned to zero.\"\"\"\n",
        "    beta = np.zeros(J_total)\n",
        "    beta[1:] = theta\n",
        "    return beta\n",
        "\n",
        "\n",
        "def loglik(theta):\n",
        "    beta = full_beta(theta)\n",
        "    best_part = beta[best_idx] - row_logsumexp(beta[shown])\n",
        "    worst_part = -beta[worst_idx] - row_logsumexp(-beta[remaining])\n",
        "    return float((best_part + worst_part).sum())\n",
        "\n",
        "\n",
        "def neg_loglik(theta):\n",
        "    return -loglik(theta)\n",
        "\n",
        "\n",
        "def grad_loglik(theta):\n",
        "    beta = full_beta(theta)\n",
        "    grad = np.zeros(J_total)\n",
        "\n",
        "    # Best-choice contribution: chosen item minus softmax probabilities over shown set.\n",
        "    v = beta[shown]\n",
        "    p_best = np.exp(v - row_logsumexp(v)[:, None])\n",
        "    np.add.at(grad, best_idx, 1.0)\n",
        "    np.add.at(grad, shown.ravel(), -p_best.ravel())\n",
        "\n",
        "    # Worst-choice contribution: chosen worst item has -1;\n",
        "    # remaining items get flipped-utility probabilities.\n",
        "    u = -beta[remaining]\n",
        "    p_worst = np.exp(u - row_logsumexp(u)[:, None])\n",
        "    np.add.at(grad, worst_idx, -1.0)\n",
        "    np.add.at(grad, remaining.ravel(), p_worst.ravel())\n",
        "\n",
        "    # Drop reference coefficient.\n",
        "    return grad[1:]\n",
        "\n",
        "\n",
        "def grad_neg_loglik(theta):\n",
        "    return -grad_loglik(theta)\n",
        "\n",
        "\n",
        "mle_out = minimize(\n",
        "    neg_loglik,\n",
        "    x0=np.zeros(J_total - 1),\n",
        "    jac=grad_neg_loglik,\n",
        "    method=\"BFGS\",\n",
        "    options={\"gtol\": 1e-7, \"maxiter\": 2000},\n",
        ")"
      ],
      "id": "mle-core-code",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: mle-output\n",
        "#| echo: true\n",
        "if not mle_out.success:\n",
        "    display(Markdown(f\"**Warning:** optimizer message: `{mle_out.message}`\"))\n",
        "\n",
        "# Finite-difference Hessian of the negative log-likelihood gradient.\n",
        "def finite_diff_jacobian(func, x, eps=1e-5):\n",
        "    x = np.asarray(x, dtype=float)\n",
        "    K = len(x)\n",
        "    J = np.empty((K, K))\n",
        "    for k in range(K):\n",
        "        step = eps * max(1.0, abs(x[k]))\n",
        "        x_plus = x.copy()\n",
        "        x_minus = x.copy()\n",
        "        x_plus[k] += step\n",
        "        x_minus[k] -= step\n",
        "        J[:, k] = (func(x_plus) - func(x_minus)) / (2 * step)\n",
        "    return J\n",
        "\n",
        "\n",
        "hess_nll = finite_diff_jacobian(grad_neg_loglik, mle_out.x)\n",
        "hess_nll = (hess_nll + hess_nll.T) / 2\n",
        "cov_mle = np.linalg.inv(hess_nll)\n",
        "se_free = np.sqrt(np.diag(cov_mle))\n",
        "\n",
        "beta_mle = full_beta(mle_out.x)\n",
        "se_mle = np.r_[np.nan, se_free]\n",
        "mle_share = softmax(beta_mle)\n",
        "\n",
        "mle_tbl = item_map.copy()\n",
        "mle_tbl[\"beta_mle\"] = beta_mle\n",
        "mle_tbl[\"se_mle\"] = se_mle\n",
        "mle_tbl[\"mle_share\"] = mle_share\n",
        "mle_tbl = mle_tbl.sort_values([\"mle_share\", \"item\"], ascending=[False, True]).reset_index(drop=True)\n",
        "mle_tbl[\"mle_rank\"] = np.arange(1, len(mle_tbl) + 1)"
