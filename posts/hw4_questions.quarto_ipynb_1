        "#| label: setup\n",
        "#| include: false\n",
        "import re\n",
        "import textwrap\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "from scipy.optimize import minimize\n",
        "from IPython.display import display, Markdown, HTML\n",
        "\n",
        "rng = np.random.default_rng(20240528)\n",
        "plt.rcParams[\"figure.dpi\"] = 120\n",
        "plt.rcParams[\"savefig.dpi\"] = 120\n",
        "\n",
        "\n",
        "def clean_colnames(cols):\n",
        "    return [re.sub(r\"[^A-Za-z0-9]+\", \"_\", str(c).strip()).strip(\"_\").lower() for c in cols]\n",
        "\n",
        "\n",
        "def pct(x, digits=1):\n",
        "    return f\"{100 * x:.{digits}f}%\"\n",
        "\n",
        "\n",
        "def pct_series(s, digits=1):\n",
        "    return s.map(lambda x: pct(x, digits))\n",
        "\n",
        "\n",
        "def fmt_num(x, digits=3):\n",
        "    return \"reference\" if pd.isna(x) else f\"{x:.{digits}f}\"\n",
        "\n",
        "\n",
        "def fmt_list(values):\n",
        "    return \"; \".join([str(v) for v in values])\n",
        "\n",
        "\n",
        "def compact_class_label(x, width=17):\n",
        "    \"\"\"Short wrapped labels for figures; tables still use full class names.\"\"\"\n",
        "    x = re.sub(r\"\\s*\\(.*\\)$\", \"\", str(x))\n",
        "    x = re.sub(r\"^MGTA\\s+\", \"\", x)\n",
        "    replacements = {\n",
        "        \"Marketing/Finance/Operations\": \"Mktg/Fin/Ops\",\n",
        "        \"Biz. Intelligence Systems\": \"BI Systems\",\n",
        "        \"AI Math, Prog., & Analytics\": \"AI Math & Prog.\",\n",
        "        \"Analytics Consulting\": \"Consulting\",\n",
        "        \"Capstone Project\": \"Capstone\",\n",
        "        \"Marketing Analytics\": \"Marketing\",\n",
        "        \"Business Analytics\": \"Business\",\n",
        "        \"Customer Analytics\": \"Customer\",\n",
        "    }\n",
        "    for old, new in replacements.items():\n",
        "        x = x.replace(old, new)\n",
        "    return \"\\n\".join(textwrap.wrap(x, width=width, break_long_words=False))\n",
        "\n",
        "\n",
        "def show_table(df, caption=None, index=False):\n",
        "    if caption is not None:\n",
        "        display(Markdown(f\"**{caption}**\"))\n",
        "    html = df.to_html(index=index, escape=False)\n",
        "    display(HTML(f'<div style=\"overflow-x:auto;\">{html}</div>'))\n",
        "\n",
        "\n",
        "def row_logsumexp(a):\n",
        "    m = np.max(a, axis=1)\n",
        "    return m + np.log(np.exp(a - m[:, None]).sum(axis=1))\n",
        "\n",
        "\n",
        "def softmax(x):\n",
        "    z = np.exp(x - np.max(x))\n",
        "    return z / z.sum()\n",
        "\n",
        "\n",
        "def add_pct_axis(ax):\n",
        "    ax.xaxis.set_major_formatter(lambda x, pos: f\"{100*x:.0f}%\")"
