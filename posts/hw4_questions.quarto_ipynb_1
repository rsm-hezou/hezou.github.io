        "A balanced MaxDiff design should expose the items roughly equally often. The table above confirms that exposure is similar across the 10 classes.\n",
        "\n",
        "## Counts Analysis\n",
        "\n",
        "The counts analysis is a simple descriptive summary of the MaxDiff responses. For each class, I calculate the percentage of times it was picked as best, the percentage of times it was picked as worst, and the difference between those two percentages:\n",
        "\n",
        "$$\n",
        "\\text{score}_j = \\%\\text{best}_j - \\%\\text{worst}_j.\n",
        "$$\n",
        "\n",
        "A score near 1 means that a class is almost always selected as best when shown. A score near -1 means that it is almost always selected as worst. A score near 0 means that the class is either middle-of-the-pack or potentially polarizing."
      ],
      "id": "dacfb30a"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: counts-analysis\n",
        "#| echo: false\n",
        "def counts_from_design(d):\n",
        "    out = (\n",
        "        d\n",
        "        .groupby([\"item\", \"item_idx\", \"item_label\", \"class_short\", \"plot_label\"], as_index=False)\n",
        "        .agg(\n",
        "            times_shown=(\"response\", \"size\"),\n",
        "            times_best=(\"response\", lambda x: (x == 1).sum()),\n",
        "            times_worst=(\"response\", lambda x: (x == -1).sum()),\n",
        "        )\n",
        "    )\n",
        "    out[\"pct_best\"] = out[\"times_best\"] / out[\"times_shown\"]\n",
        "    out[\"pct_worst\"] = out[\"times_worst\"] / out[\"times_shown\"]\n",
        "    out[\"counts_score\"] = out[\"pct_best\"] - out[\"pct_worst\"]\n",
        "    out = out.sort_values([\"counts_score\", \"item\"], ascending=[False, True]).reset_index(drop=True)\n",
        "    out[\"counts_rank\"] = np.arange(1, len(out) + 1)\n",
        "    return out\n",
        "\n",
        "\n",
        "counts_tbl = counts_from_design(design)\n",
        "\n",
        "# Bootstrap respondents, not individual rows, so each respondent's task pattern stays together.\n",
        "B = 1000\n",
        "respondents = np.array(sorted(design[\"record_id\"].unique()))\n",
        "N_resp = len(respondents)\n",
        "per_resp_item = (\n",
        "    design\n",
        "    .groupby([\"record_id\", \"item_idx\"])\n",
        "    .agg(\n",
        "        shown=(\"response\", \"size\"),\n",
        "        best=(\"response\", lambda x: (x == 1).sum()),\n",
        "        worst=(\"response\", lambda x: (x == -1).sum()),\n",
        "    )\n",
        "    .reset_index()\n",
        ")\n",
        "\n",
        "shown_mat = np.zeros((N_resp, J_total))\n",
        "best_mat = np.zeros((N_resp, J_total))\n",
        "worst_mat = np.zeros((N_resp, J_total))\n",
        "resp_to_row = {rid: i for i, rid in enumerate(respondents)}\n",
        "\n",
        "for row in per_resp_item.itertuples(index=False):\n",
        "    i = resp_to_row[row.record_id]\n",
        "    j = int(row.item_idx)\n",
        "    shown_mat[i, j] = row.shown\n",
        "    best_mat[i, j] = row.best\n",
        "    worst_mat[i, j] = row.worst\n",
        "\n",
        "boot_scores = np.empty((B, J_total))\n",
        "for b in range(B):\n",
        "    idx = rng.integers(0, N_resp, size=N_resp)\n",
        "    shown_b = shown_mat[idx].sum(axis=0)\n",
        "    best_b = best_mat[idx].sum(axis=0)\n",
        "    worst_b = worst_mat[idx].sum(axis=0)\n",
        "    boot_scores[b, :] = best_b / shown_b - worst_b / shown_b\n",
        "\n",
        "ci_low = np.quantile(boot_scores, 0.025, axis=0)\n",
        "ci_high = np.quantile(boot_scores, 0.975, axis=0)\n",
        "counts_tbl = counts_tbl.merge(\n",
        "    pd.DataFrame({\"item_idx\": np.arange(J_total), \"count_ci_low\": ci_low, \"count_ci_high\": ci_high}),\n",
        "    on=\"item_idx\",\n",
        "    how=\"left\",\n",
        ")\n",
        "\n",
        "counts_display = pd.DataFrame({\n",
        "    \"Rank\": counts_tbl[\"counts_rank\"],\n",
        "    \"Item\": counts_tbl[\"item\"],\n",
        "    \"Class\": counts_tbl[\"item_label\"],\n",
        "    \"Times shown\": counts_tbl[\"times_shown\"],\n",
        "    \"Times best\": counts_tbl[\"times_best\"],\n",
        "    \"Times worst\": counts_tbl[\"times_worst\"],\n",
        "    \"% best\": pct_series(counts_tbl[\"pct_best\"]),\n",
        "    \"% worst\": pct_series(counts_tbl[\"pct_worst\"]),\n",
        "    \"Counts score\": pct_series(counts_tbl[\"counts_score\"]),\n",
        "    \"95% bootstrap CI\": [\n",
        "        f\"[{pct(lo)}, {pct(hi)}]\" for lo, hi in zip(counts_tbl[\"count_ci_low\"], counts_tbl[\"count_ci_high\"])\n",
        "    ],\n",
        "})\n",
        "show_table(counts_display, \"Counts analysis ranked by best-minus-worst score\")"
      ],
      "id": "counts-analysis",
      "execution_count": null,
      "outputs": []
    },
