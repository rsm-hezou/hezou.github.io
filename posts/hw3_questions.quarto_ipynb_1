        ")\n",
        "\n",
        "poisson_regression_y = (\n",
        "    poisson_regression_data\n",
        "    .select(\"patents\")\n",
        "    .to_series()\n",
        "    .to_numpy()\n",
        ")\n",
        "\n",
        "poisson_regression_region_values = (\n",
        "    poisson_regression_data\n",
        "    .select(\"region\")\n",
        "    .to_series()\n",
        "    .to_numpy()\n",
        ")\n",
        "\n",
        "poisson_regression_reference_region = \"Midwest\"\n",
        "\n",
        "poisson_regression_region_dummy_names = [\n",
        "    \"Northeast\",\n",
        "    \"Northwest\",\n",
        "    \"South\",\n",
        "    \"Southwest\"\n",
        "]\n",
        "\n",
        "poisson_regression_x = np.column_stack([\n",
        "    np.ones(poisson_regression_data.height),\n",
        "    poisson_regression_data.select(\"age\").to_series().to_numpy(),\n",
        "    poisson_regression_data.select(\"age_squared\").to_series().to_numpy(),\n",
        "    (poisson_regression_region_values == \"Northeast\").astype(int),\n",
        "    (poisson_regression_region_values == \"Northwest\").astype(int),\n",
        "    (poisson_regression_region_values == \"South\").astype(int),\n",
        "    (poisson_regression_region_values == \"Southwest\").astype(int),\n",
        "    poisson_regression_data.select(\"iscustomer\").to_series().to_numpy()\n",
        "])\n",
        "\n",
        "poisson_regression_variable_names = [\n",
        "    \"Intercept\",\n",
        "    \"Age\",\n",
        "    \"Age squared\",\n",
        "    \"Northeast\",\n",
        "    \"Northwest\",\n",
        "    \"South\",\n",
        "    \"Southwest\",\n",
        "    \"Blueprinty customer\"\n",
        "]"
