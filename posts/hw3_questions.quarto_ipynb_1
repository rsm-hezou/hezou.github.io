      "source": [
        "#| label: poisson-regression-mle\n",
        "#| warning: false\n",
        "\n",
        "def poisson_regression_loglikelihood(beta_values, x_values, y_values):\n",
        "    linear_prediction_values = x_values @ beta_values\n",
        "    lambda_values = np.exp(linear_prediction_values)\n",
        "\n",
        "    loglikelihood_values = (\n",
        "        -lambda_values\n",
        "        + y_values * linear_prediction_values\n",
        "        - gammaln(y_values + 1)\n",
        "    )\n",
        "\n",
        "    return loglikelihood_values.sum()\n",
        "\n",
        "\n",
        "def poisson_regression_negative_loglikelihood(beta_values, x_values, y_values):\n",
        "    return -poisson_regression_loglikelihood(beta_values, x_values, y_values)\n",
        "\n",
        "\n",
        "def poisson_regression_gradient_negative_loglikelihood(beta_values, x_values, y_values):\n",
        "    linear_prediction_values = x_values @ beta_values\n",
        "    lambda_values = np.exp(linear_prediction_values)\n",
        "\n",
        "    gradient_values = x_values.T @ (lambda_values - y_values)\n",
        "\n",
        "    return gradient_values\n",
        "\n",
        "\n",
        "def poisson_regression_hessian_negative_loglikelihood(beta_values, x_values, y_values):\n",
        "    linear_prediction_values = x_values @ beta_values\n",
        "    lambda_values = np.exp(linear_prediction_values)\n",
        "\n",
        "    hessian_values = x_values.T @ (lambda_values[:, None] * x_values)\n",
        "\n",
        "    return hessian_values\n",
        "\n",
        "\n",
        "poisson_regression_initial_beta = np.zeros(poisson_regression_x.shape[1])\n",
        "poisson_regression_initial_beta[0] = np.log(poisson_regression_y.mean())\n",
        "\n",
        "poisson_regression_mle_result = minimize(\n",
        "    poisson_regression_negative_loglikelihood,\n",
        "    x0=poisson_regression_initial_beta,\n",
        "    args=(poisson_regression_x, poisson_regression_y),\n",
        "    method=\"trust-exact\",\n",
        "    jac=poisson_regression_gradient_negative_loglikelihood,\n",
        "    hess=poisson_regression_hessian_negative_loglikelihood\n",
        ")\n",
        "\n",
        "poisson_regression_beta_mle = poisson_regression_mle_result.x\n",
        "\n",
        "poisson_regression_hessian_mle = poisson_regression_hessian_negative_loglikelihood(\n",
        "    poisson_regression_beta_mle,\n",
        "    poisson_regression_x,\n",
        "    poisson_regression_y\n",
        ")\n",
        "\n",
        "poisson_regression_covariance_matrix = np.linalg.inv(poisson_regression_hessian_mle)\n",
        "poisson_regression_standard_errors = np.sqrt(np.diag(poisson_regression_covariance_matrix))\n",
        "poisson_regression_z_values = poisson_regression_beta_mle / poisson_regression_standard_errors\n",
        "\n",
        "poisson_regression_mle_result.success, poisson_regression_mle_result.message"
      ],
      "id": "poisson-regression-mle",
      "execution_count": null,
      "outputs": []
    },
