    "import statsmodels.api as sm\n",
    "\n",
    "# Table 4, column (i): use stores with non-missing employment and wage data in both waves\n",
    "t4 = df[[\"fte\", \"fte2\", \"wage\", \"wage2\", \"state\"]].dropna().copy()\n",
    "\n",
    "# Change in employment\n",
    "t4[\"d_fte\"] = t4[\"fte2\"] - t4[\"fte\"]\n",
    "\n",
    "# OLS: change in employment on New Jersey dummy\n",
    "X = sm.add_constant(t4[\"state\"])\n",
    "y = t4[\"d_fte\"]\n",
    "\n",
    "model_t4_col1 = sm.OLS(y, X).fit()\n",
    "\n",
    "# Extract values\n",
    "coef = model_t4_col1.params[\"state\"]\n",
    "se = model_t4_col1.bse[\"state\"]\n",
    "ser = np.sqrt(model_t4_col1.scale)\n",
    "\n",
    "# Build a table in the style of Table 4, column (i)\n",
    "table4_col1 = pd.DataFrame({\n",
