    "import numpy as np\n",
    "\n",
    "df = df.replace(\".\", np.nan)\n",
    "df = df.apply(pd.to_numeric, errors=\"coerce\")\n",
    "\n",
    "# state name\n",
    "df[\"state_name\"] = df[\"state\"].map({1: \"NJ\", 0: \"PA\"})\n",
    "\n",
    "# FTE\n",
    "df[\"fte\"] = df[\"empft\"] + df[\"nmgrs\"] + 0.5 * df[\"emppt\"]\n",
    "df[\"fte2\"] = df[\"empft2\"] + df[\"nmgrs2\"] + 0.5 * df[\"emppt2\"]\n",
    "\n",
    "# wage\n",
    "df[\"wage\"] = df[\"wage_st\"]\n",
    "df[\"wage2\"] = df[\"wage_st2\"]\n",
    "\n",
    "# price\n",
    "df[\"price\"] = df[\"psoda\"] + df[\"pfry\"] + df[\"pentree\"]\n",
    "df[\"price2\"] = df[\"psoda2\"] + df[\"pfry2\"] + df[\"pentree2\"]\n",
    "\n",
    "df[[\"state_name\",\"fte\",\"fte2\",\"wage\",\"wage2\",\"price\",\"price2\"]].head()"
